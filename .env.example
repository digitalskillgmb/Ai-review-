# =======================================
# FRONTEND ENVIRONMENT VARIABLES
# =======================================
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=164402372364-quce6mdoqekvbk6l3h0pd3khhovqi7rc.apps.googleusercontent.com
NEXT_PUBLIC_APP_NAME=GBP Automation
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =======================================
# BACKEND ENVIRONMENT VARIABLES
# =======================================
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/gbp-automation
DATABASE_URL=postgresql://user:password@localhost:5432/gbp_automation
DB_TYPE=mongodb

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-12345
JWT_EXPIRE=7d
JWT_REFRESH_EXPIRE=30d
JWT_REFRESH_SECRET=your-refresh-secret-key-12345

# Google OAuth Configuration
GOOGLE_CLIENT_ID=164402372364-quce6mdoqekvbk6l3h0pd3khhovqi7rc.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:5000/auth/google/callback
GOOGLE_SCOPES=business.manage profile email openid

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=500

# Email Service Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@gbpautomation.com
FROM_NAME=GBP Automation

# Admin Configuration
ADMIN_EMAIL=admin@gbpautomation.com
ADMIN_PASSWORD=Change@This123!
ADMIN_NAME=Admin User

# Security Configuration
CORS_ORIGIN=http://localhost:3000,http://localhost:3001
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100
ENCRYPTION_KEY=your-32-character-encryption-key!!

# Logging Configuration
LOG_LEVEL=debug
LOG_FILE=true

# API Configuration
API_KEY_EXPIRATION=90
API_VERSION=v1

# WhatsApp Configuration (Optional)
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER=your-phone-number

# Telegram Configuration (Optional)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# AWS Configuration (Optional for file upload)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=gbp-automation-bucket

# Redis Configuration (Optional for caching)
REDIS_URL=redis://localhost:6379

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_URL=https://your-domain.com/webhooks
